# Google Sign-In Configuration
# Get these values from Google Cloud Console
# See docs/GOOGLE_SIGNIN_SETUP.md for detailed instructions

EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID=YOUR_IOS_CLIENT_ID.apps.googleusercontent.com
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=YOUR_WEB_CLIENT_ID.apps.googleusercontent.com

# Same as EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID, but needed for Supabase auth configuration
SUPABASE_AUTH_EXTERNAL_GOOGLE_CLIENT_ID=YOUR_WEB_CLIENT_ID.apps.googleusercontent.com

# Supabase Configuration
EXPO_PUBLIC_SUPABASE_URL=YOUR_SUPABASE_URL
EXPO_PUBLIC_SUPABASE_KEY=YOUR_SUPABASE_ANON_KEY
